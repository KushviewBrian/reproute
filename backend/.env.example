# ── Core ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/reproute
# Production: set DATABASE_TLS_VERIFY=true and populate DATABASE_SSL_CA_PEM
DATABASE_TLS_VERIFY=false
DATABASE_SSL_CA_PEM=
DATABASE_TLS_EMERGENCY_INSECURE_OVERRIDE=false
DATABASE_TLS_EMERGENCY_OVERRIDE_SUNSET=2026-06-30

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
# Get from Clerk dashboard → API Keys / JWT Templates
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_AUDIENCE=
CLERK_AUTHORIZED_PARTY=

# ── Geocoding (Photon / Cloudflare Worker) ────────────────────────────────────
GEOCODE_WORKER_URL=https://photon.komoot.io/api/
GEOCODE_TIMEOUT_SECONDS=4

# ── Routing (OpenRouteService) ────────────────────────────────────────────────
ORS_API_KEY=
ORS_BASE_URL=https://api.openrouteservice.org
ROUTE_CACHE_TTL_SECONDS=86400

# ── OSM Enrichment (Overpass) ─────────────────────────────────────────────────
# Use an alternate endpoint if the public one times out on your host:
#   OVERPASS_ENDPOINT=https://overpass.kumi.systems/api/interpreter
OVERPASS_ENDPOINT=https://overpass-api.de/api/interpreter
OVERPASS_TIMEOUT_SECONDS=10
OVERPASS_RADIUS_METERS=50
ENRICHMENT_DAILY_CAP=100
ENRICHMENT_MONTHLY_CAP=2000
ENRICHMENT_PER_USER_DAILY_CAP=15
ENRICHMENT_FRESHNESS_DAYS=30

# ── Scoring ───────────────────────────────────────────────────────────────────
SCORING_DEFAULT_VERSION=v1
SCORING_V2_ENABLED=false
SCORING_V2_SHADOW_ENABLED=true

# ── Lead Validation ───────────────────────────────────────────────────────────
VALIDATION_HMAC_SECRET=change-me-in-production
VALIDATION_DAILY_CAP=50
VALIDATION_MONTHLY_CAP=2000
VALIDATION_PER_USER_DAILY_CAP=15
VALIDATION_HTTP_TIMEOUT_SECONDS=5
VALIDATION_RETRY_DELAY_SECONDS=3
VALIDATION_ADMIN_TOKEN_TTL_SECONDS=60

# ── Admin / Ingestion ─────────────────────────────────────────────────────────
ADMIN_IMPORT_SECRET=change-me
ADMIN_ALLOWED_EMAILS=you@example.com
ADMIN_IMPORT_ALLOWED_ROOTS=/tmp
INGEST_DATABASE_URL=

# ── Security / CORS ───────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-change-in-production
CORS_ALLOW_ORIGINS=http://localhost:5173
CORS_ALLOW_ORIGIN_REGEX=
REQUEST_BODY_LIMIT_BYTES=1048576

# ── Feature flags ─────────────────────────────────────────────────────────────
POC_MODE=false
