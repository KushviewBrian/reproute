# Environment
ENVIRONMENT=development
POC_MODE=false
POC_USER_EMAIL=poc@local.dev

# Database - Get from Supabase or your PostgreSQL provider
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database
DATABASE_TLS_VERIFY=false
DATABASE_SSL_CA_PEM=
DATABASE_TLS_EMERGENCY_INSECURE_OVERRIDE=false
DATABASE_TLS_EMERGENCY_OVERRIDE_SUNSET=2026-06-30

# Redis - Get from Upstash (https://upstash.com)
# Optional: app degrades gracefully without Redis
REDIS_URL=https://your-redis-url.upstash.io

# Security
SECRET_KEY=generate-a-long-random-string-here

# CORS - Add your frontend URLs
CORS_ALLOW_ORIGINS=http://localhost:5173,https://your-frontend-domain.com
CORS_ALLOW_ORIGIN_REGEX=
REQUEST_BODY_LIMIT_BYTES=1048576

# Geocoding - Get from Cloudflare Worker deployment
GEOCODE_WORKER_URL=https://reproute-geocode.your-subdomain.workers.dev

# OpenRouteService (optional for advanced routing)
ORS_BASE_URL=https://api.openrouteservice.org
ORS_API_KEY=

# Admin import (Phase 1 admin endpoints)
# Optional sync URL for ingest script; if blank, DATABASE_URL is converted from asyncpg to psycopg.
INGEST_DATABASE_URL=
# Required in production to authorize /admin/import endpoints
ADMIN_IMPORT_SECRET=
ADMIN_ALLOWED_EMAILS=
ADMIN_IMPORT_ALLOWED_ROOTS=
VALIDATION_HMAC_SECRET=
VALIDATION_DAILY_CAP=50
VALIDATION_MONTHLY_CAP=2000
VALIDATION_PER_USER_DAILY_CAP=15
VALIDATION_HTTP_TIMEOUT_SECONDS=5
VALIDATION_RETRY_DELAY_SECONDS=3
VALIDATION_ADMIN_TOKEN_TTL_SECONDS=60

# Clerk Authentication - Get from clerk.com
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_AUDIENCE=
CLERK_AUTHORIZED_PARTY=
